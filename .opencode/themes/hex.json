{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "hexGreen":      "#00d4aa",
    "hexGreenDim":   "#00a882",
    "hexNavy":       "#0a0f1e",
    "hexPanel":      "#0e1528",
    "hexElement":    "#131d35",
    "hexMenu":       "#111827",
    "hexBorder":     "#1e2d4a",
    "hexBorderHi":   "#00d4aa",
    "hexBorderSub":  "#162035",
    "hexText":       "#e2e8f0",
    "hexMuted":      "#64748b",
    "hexAccent":     "#818cf8",
    "hexAmber":      "#f59e0b",
    "hexRed":        "#f87171",
    "hexBlue":       "#60a5fa",
    "hexPurple":     "#a78bfa",
    "hexCyan":       "#22d3ee",
    "hexOrange":     "#fb923c"
  },
  "theme": {
    "primary":     { "dark": "hexGreen",   "light": "hexGreenDim" },
    "secondary":   { "dark": "hexAccent",  "light": "#6366f1" },
    "accent":      { "dark": "hexCyan",    "light": "#0891b2" },
    "error":       { "dark": "hexRed",     "light": "#dc2626" },
    "warning":     { "dark": "hexAmber",   "light": "#d97706" },
    "success":     { "dark": "hexGreen",   "light": "hexGreenDim" },
    "info":        { "dark": "hexBlue",    "light": "#2563eb" },

    "text":        { "dark": "hexText",    "light": "#1e293b" },
    "textMuted":   { "dark": "hexMuted",   "light": "#94a3b8" },

    "background":        { "dark": "hexNavy",    "light": "#f8fafc" },
    "backgroundPanel":   { "dark": "hexPanel",   "light": "#f1f5f9" },
    "backgroundElement": { "dark": "hexElement", "light": "#e2e8f0" },
    "backgroundMenu":    { "dark": "hexMenu",    "light": "#ffffff" },

    "border":       { "dark": "hexBorder",    "light": "#cbd5e1" },
    "borderActive": { "dark": "hexBorderHi",  "light": "hexGreenDim" },
    "borderSubtle": { "dark": "hexBorderSub", "light": "#e2e8f0" },

    "diffAdded":              { "dark": "#00d4aa",  "light": "#059669" },
    "diffRemoved":            { "dark": "hexRed",   "light": "#dc2626" },
    "diffContext":            { "dark": "hexMuted", "light": "#64748b" },
    "diffHunkHeader":         { "dark": "hexAccent","light": "#6366f1" },
    "diffHighlightAdded":     { "dark": "#00d4aa",  "light": "#059669" },
    "diffHighlightRemoved":   { "dark": "hexRed",   "light": "#dc2626" },
    "diffAddedBg":            { "dark": "#001f18",  "light": "#ecfdf5" },
    "diffRemovedBg":          { "dark": "#1f0a0a",  "light": "#fef2f2" },
    "diffContextBg":          { "dark": "hexPanel", "light": "#f8fafc" },
    "diffLineNumber":         { "dark": "hexMuted", "light": "#94a3b8" },
    "diffAddedLineNumberBg":  { "dark": "#00261d",  "light": "#d1fae5" },
    "diffRemovedLineNumberBg":{ "dark": "#2d1010",  "light": "#fee2e2" },

    "markdownText":            { "dark": "hexText",    "light": "#1e293b" },
    "markdownHeading":         { "dark": "hexGreen",   "light": "hexGreenDim" },
    "markdownLink":            { "dark": "hexCyan",    "light": "#0891b2" },
    "markdownLinkText":        { "dark": "hexBlue",    "light": "#2563eb" },
    "markdownCode":            { "dark": "hexOrange",  "light": "#c2410c" },
    "markdownBlockQuote":      { "dark": "hexMuted",   "light": "#94a3b8" },
    "markdownEmph":            { "dark": "hexAccent",  "light": "#6366f1" },
    "markdownStrong":          { "dark": "hexText",    "light": "#0f172a" },
    "markdownHorizontalRule":  { "dark": "hexBorder",  "light": "#cbd5e1" },
    "markdownListItem":        { "dark": "hexGreen",   "light": "hexGreenDim" },
    "markdownListEnumeration": { "dark": "hexCyan",    "light": "#0891b2" },
    "markdownImage":           { "dark": "hexPurple",  "light": "#7c3aed" },
    "markdownImageText":       { "dark": "hexMuted",   "light": "#94a3b8" },
    "markdownCodeBlock":       { "dark": "hexOrange",  "light": "#c2410c" },

    "syntaxComment":     { "dark": "#3d5a80",   "light": "#94a3b8" },
    "syntaxKeyword":     { "dark": "hexPurple", "light": "#7c3aed" },
    "syntaxFunction":    { "dark": "hexGreen",  "light": "hexGreenDim" },
    "syntaxVariable":    { "dark": "hexBlue",   "light": "#2563eb" },
    "syntaxString":      { "dark": "hexOrange", "light": "#c2410c" },
    "syntaxNumber":      { "dark": "hexCyan",   "light": "#0891b2" },
    "syntaxType":        { "dark": "hexAmber",  "light": "#d97706" },
    "syntaxOperator":    { "dark": "hexCyan",   "light": "#0891b2" },
    "syntaxPunctuation": { "dark": "hexMuted",  "light": "#64748b" },

    "selectedListItemText": { "dark": "hexNavy",  "light": "#ffffff" },
    "thinkingOpacity":      { "dark": "0.45",     "light": "0.45" }
  }
}

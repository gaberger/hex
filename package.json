{
  "name": "hex-intf",
  "version": "0.1.0",
  "description": "Hexagonal Architecture framework for LLM-driven development with token-efficient tree-sitter summaries",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hex-intf": "dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outfile dist/cli.js --target node --format esm && bun build src/index.ts --outfile dist/index.js --target node --format esm && cp node_modules/web-tree-sitter/tree-sitter.wasm dist/tree-sitter.wasm 2>/dev/null || true",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "bun run --watch src/cli.ts",
    "start": "bun src/cli.ts",
    "prepublishOnly": "bun run clean && bun run build && bun test"
  },
  "keywords": [
    "hexagonal-architecture",
    "ports-and-adapters",
    "llm",
    "tree-sitter",
    "code-generation",
    "ai-development",
    "swarm"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "skills",
    "agents",
    "config"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@claude-flow/cli": "^3.5.15",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.25.10"
  }
}

      "title": "hex-agent workplan executor",
      "tasks": [
        {
          "id": "P1.1",
          "title": "Add hex-agent binary entry point with --workplan <id> --background flags. Reads workplan JSON from disk (or memory via hex memory get workplan:<id>).",
          "status": "done",
          "strategy_hint": "codegen",
          "files": [
            "hex-agent/src/main.rs",
            "hex-agent/Cargo.toml"
          ],
          "evidence": [
            "hex-agent --help | grep workplan",
            "cargo build -p hex-agent --release",
            "cargo test -p hex-agent cli_args"
          ]
        },
        {
          "id": "P1.2",
          "title": "Implement task iterator: reads workplan JSON, filters tasks with status=pending, returns Vec<Task> with id, title, strategy_hint, files, evidence.",
          "status": "done",
          "strategy_hint": "codegen",
          "files": [
            "hex-agent/src/workplan.rs"
          ],
          "evidence": [
            "grep -n 'fn pending_tasks' hex-agent/src/workplan.rs",
            "cargo test -p hex-agent pending_tasks"

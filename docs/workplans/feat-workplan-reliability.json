{
  "id": "feat-workplan-reliability",
  "adr": "ADR-2604101800",
  "description": "Fix workplan status transitions, progress visibility, and trust issues in autonomous agent execution",
  "feature": "Workplan Reliability & Trust",
  "dependsOn": ["feat-stdb-agent-workflow", "feat-managed-agents-autonomy"],
  "phases": [
    {
      "id": "P0",
      "name": "Fix Final Status Transition",
      "dependsOn": [],
      "gate": {
        "gate_type": "build",
        "command": "cargo check --package hex-nexus",
        "blocking": true
      },
      "tasks": [
        {
          "id": "T0.1",
          "name": "Add workplan_finalize reducer",
          "layer": "spacetime",
          "description": "Add reducer that transitions workplan from 'running' to 'completed' or 'failed'",
          "files": ["spacetime-modules/hexflo-coordination/src/lib.rs"],
          "done_condition": "cargo check --package hexflo-coordination",
          "done_command": "ls spacetime-modules/hexflo-coordination/src/lib.rs",
          "deps": []
        },
        {
          "id": "T0.2",
          "name": "Call finalize in executor",
          "layer": "adapters/secondary",
          "description": "Modify workplan_executor to call workplan_finalize after all phases complete",
          "files": ["hex-nexus/src/orchestration/workplan_executor.rs"],
          "done_condition": "cargo check --package hex-nexus -- workplan",
          "done_command": "cargo test --package hex-nexus -- workplan",
          "deps": ["T0.1"]
        }
      ]
    },
    {
      "id": "P1",
      "name": "Add Progress Heartbeats",
      "dependsOn": ["P0"],
      "gate": {
        "gate_type": "build",
        "command": "cargo check --package hex-nexus",
        "blocking": true
      },
      "tasks": [
        {
          "id": "T1.1",
          "name": "Add progress heartbeat in task_start",
          "layer": "spacetime",
          "description": "Add log or memory store on task_start to signal task began",
          "files": ["spacetime-modules/hexflo-coordination/src/lib.rs"],
          "done_condition": "ls spacetime-modules/hexflo-coordination/src/lib.rs",
          "done_command": "ls spacetime-modules/hexflo-coordination/src/lib.rs",
          "deps": ["T0.2"]
        },
        {
          "id": "T1.2",
          "name": "Add progress heartbeat in task_complete",
          "layer": "spacetime",
          "description": "Add log or memory store on task_complete to signal task ended",
          "files": ["spacetime-modules/hexflo-coordination/src/lib.rs"],
          "done_condition": "ls spacetime-modules/hexflo-coordination/src/lib.rs",
          "done_command": "ls spacetime-modules/hexflo-coordination/src/lib.rs",
          "deps": ["T1.1"]
        },
        {
          "id": "T1.3",
          "name": "Expose via hex plan history",
          "layer": "adapters/primary",
          "description": "Show running tasks with progress in hex plan history output",
          "files": ["hex-cli/src/commands/plan.rs"],
          "done_condition": "cargo check -p hex-cli",
          "done_command": "cargo check -p hex-cli",
          "deps": ["T1.2"]
        }
      ]
    },
    {
      "id": "P2",
      "name": "Add Dedup for Same Workplan",
      "dependsOn": ["P1"],
      "gate": {
        "gate_type": "build",
        "command": "cargo check --package hex-cli",
        "blocking": true
      },
      "tasks": [
        {
          "id": "T2.1",
          "name": "Deduplicate execution IDs",
          "layer": "adapters/secondary",
          "description": "Prevent duplicate executions of same workplan by checking for running instance",
          "files": ["hex-nexus/src/orchestration/workplan_executor.rs"],
          "done_condition": "cargo check --package hex-nexus",
          "done_command": "cargo check --package hex-nexus",
          "deps": ["T1.3"]
        }
      ]
    },
    {
      "id": "P3",
      "name": "Integration Test",
      "dependsOn": ["P2"],
      "gate": {
        "gate_type": "test",
        "command": "cargo test --package hex-cli -- workplan",
        "blocking": true
      },
      "tasks": [
        {
          "id": "T3.1",
          "name": "End-to-end reliability test",
          "layer": "integration",
          "description": "Run workplan and verify final status is 'completed' not 'running'",
          "files": [],
          "done_condition": "hex plan history | grep completed",
          "done_command": "hex plan history | grep completed",
          "deps": ["T2.1"]
        }
      ]
    }
  ],
  "status": "planned",
  "successCriteria": [
    "hex plan history shows 'completed' not 'running' after workplan finishes",
    "Progress visible via hex plan history during execution",
    "No duplicate execution IDs for same workplan",
    "All gates pass with consistent status"
  ]
}
{
  "id": "wp-memory-health-swarm",
  "title": "Memory Health Swarm",
  "phases": [
    {
      "id": "P1",
      "title": "Memory assessment + categorization",
      "tasks": [
        {
          "id": "P1.1",
          "title": "Add memory query endpoint GET /api/memory/health returning JSON with total_entries, categories breakdown, stale_count, failed_brain_tasks grouped by error pattern.",
          "status": "done",
          "strategy_hint": "codegen",
          "files": [
            "hex-nexus/src/routes/memory_health.rs",
            "hex-nexus/src/routes/mod.rs"
          ],
          "evidence": [
            "curl -s http://localhost:5555/api/memory/health | jq '.total_entries'",
            "cargo test -p hex-nexus memory_health"
          ]
        },
        {
          "id": "P1.2",
          "title": "Implement staleness detection: brain-tasks with status=in_progress AND leased_until > 2h ago OR status=failed → return stale task IDs + category (transient, superseded, compile_blocker, inference_stall, duplicate, unknown).",
          "status": "done",
          "strategy_hint": "codegen",
          "files": [
            "hex-nexus/src/memory/categorizer.rs",
            "hex-nexus/src/memory/mod.rs"
          ],
          "evidence": [
            "grep -n 'fn categorize_failure' hex-nexus/src/memory/categorizer.rs",
            "cargo test -p hex-nexus categorize_failure"
          ]
        },
        {
          "id": "P1.3",
          "title": "Implement workplan-memory drift detection: query workplan:*:outcome entries, load workplan JSON from disk, flag entries where memory shows failed/in_progress but JSON shows done.",
          "status": "done",
          "strategy_hint": "codegen",
          "files": [
            "hex-nexus/src/memory/drift_detector.rs"
          ],
          "evidence": [
            "grep -n 'fn detect_workplan_drift' hex-nexus/src/memory/drift_detector.rs",
            "cargo test -p hex-nexus detect_workplan_drift"
          ]
        },
        {
          "id": "P1.4",
          "title": "Add growth metrics calculation: entries added in last 24h, last 7d, failure rate (failed / completed brain-tasks in 7d window). Store in memory-health response.",
          "status": "done",
          "strategy_hint": "codegen",
          "files": [
            "hex-nexus/src/memory/metrics.rs"
          ],
          "evidence": [
            "curl -s http://localhost:5555/api/memory/health | jq '.growth_metrics'",
            "cargo test -p hex-nexus memory_metrics"
          ]
        }
      ]
    },
    {
      "id": "P2",
      "title": "Action handlers (retry, archive, escalate)",
      "tasks": [
        {
          "id": "P2.1",
          "title": "Implement archive action: POST /api/memory/archive with task_id — adds archived:true field to memory entry, preserves original data. Returns success/error.",
          "status": "done",
          "strategy_hint": "codegen",
          "files": [
            "hex-nexus/src/routes/memory_health.rs"
          ],
          "evidence": [
            "curl -X POST http://localhost:5555/api/memory/archive -d '{\"task_id\":\"test-id\"}' -H 'Content-Type: application/json'",
            "cargo test -p hex-nexus memory_archive"
          ]
        },
        {
          "id": "P2.2",
          "title": "Implement retry action: POST /api/memory/retry with task_id — extracts payload from old brain-task, self-enqueues new task with note 'retry of <old-id>', respects max_retries config (default 2).",
          "status": "done",
          "strategy_hint": "codegen",
          "files": [
            "hex-nexus/src/routes/memory_health.rs",
            "hex-nexus/src/memory/retry.rs"
          ],
          "evidence": [
            "curl -X POST http://localhost:5555/api/memory/retry -d '{\"task_id\":\"test-id\"}' -H 'Content-Type: application/json'",
            "hex sched queue list | grep 'retry of'",
            "cargo test -p hex-nexus memory_retry"
          ]
        },
        {
          "id": "P2.3",
          "title": "Implement escalate action: POST /api/memory/escalate with task_id — writes ADR draft under docs/adrs/drafts/ADR-<timestamp>-<category>.md with failure details, suggested fix. Returns draft path.",
          "status": "done",
          "strategy_hint": "codegen",
          "files": [
            "hex-nexus/src/memory/escalate.rs"
          ],
          "evidence": [
            "curl -X POST http://localhost:5555/api/memory/escalate -d '{\"task_id\":\"test-id\",\"category\":\"compile_blocker\"}' -H 'Content-Type: application/json'",
            "ls docs/adrs/drafts/ | grep compile_blocker",
            "cargo test -p hex-nexus memory_escalate"
          ]
        },
        {
          "id": "P2.4",
          "title": "Add batch action endpoint POST /api/memory/health/execute — accepts {\"actions\": [{\"task_id\": \"...\", \"action\": \"retry|archive|escalate\"}]} and executes all, returns summary {\"retried\": N, \"archived\": N, \"escalated\": N}.",
          "status": "pending",
          "strategy_hint": "codegen",
          "files": [
            "hex-nexus/src/routes/memory_health.rs"
          ],
          "evidence": [
            "curl -X POST http://localhost:5555/api/memory/health/execute -d '{\"actions\":[{\"task_id\":\"t1\",\"action\":\"archive\"}]}' -H 'Content-Type: application/json' | jq '.archived'",
            "cargo test -p hex-nexus memory_batch_execute"
          ]
        }
      ]
    },
    {
      "id": "P3",
      "title": "Daemon integration",
      "tasks": [
        {
          "id": "P3.1",
          "title": "Add memory-health task kind to sched daemon: auto-enqueue every health_check_interval_h (default 1h, configurable via .hex/project.json → memory.health_check_interval_h). Persist last_health_check timestamp at ~/.hex/sched/last_memory_health_check.",
          "status": "pending",
          "strategy_hint": "codegen",
          "files": [
            "hex-cli/src/commands/sched.rs"
          ],
          "evidence": [
            "grep -n 'memory-health\\|last_memory_health_check' hex-cli/src/commands/sched.rs",
            "hex sched queue list | grep memory-health",
            "cargo test -p hex-cli memory_health_trigger"
          ]
        },
        {
          "id": "P3.2",
          "title": "Implement memory-health task executor: calls GET /api/memory/health, categorizes failures, generates actions list, calls POST /api/memory/health/execute, writes report to docs/analysis/memory-health-YYYYMMDD-HHMM.yaml + .md summary.",
          "status": "pending",
          "strategy_hint": "codegen",
          "files": [
            "hex-cli/src/commands/sched.rs"
          ],
          "evidence": [
            "ls docs/analysis/ | grep memory-health",
            "cat docs/analysis/memory-health-*.yaml | grep actions_taken",
            "cargo test -p hex-cli memory_health_executor"
          ]
        },
        {
          "id": "P3.3",
          "title": "Add config schema to .hex/project.json: memory.health_check_interval_h (default 1), memory.cleanup.archive_after_days (default 90), memory.cleanup.max_retries (default 2). Load in daemon.",
          "status": "pending",
          "strategy_hint": "scaffold",
          "files": [
            ".hex/project.json",
            "hex-core/src/config.rs"
          ],
          "evidence": [
            "jq '.memory' .hex/project.json",
            "cargo check -p hex-core"
          ]
        }
      ]
    },
    {

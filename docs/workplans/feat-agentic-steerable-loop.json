{
  "id": "feat-agentic-steerable-loop",
  "feature": "Agentic Steerable Loop",
  "description": "Complete steering implementation: polling in workplan executor + continuous agent loop that runs until tested output. Implements ADR-2604102100.",
  "status": "planned",
  "adr": "ADR-2604102100",
  "phases": [
    {
      "id": "P1",
      "name": "Instruction Polling in Workplan Executor",
      "tier": 1,
      "tasks": [
        {
          "id": "T1.1",
          "name": "Add polling call after each phase completes",
          "layer": "adapters/secondary",
          "description": "After each workplan phase executes, poll /api/steering/{agent_id}/instructions and handle pause/resume/stop",
          "deps": [],
          "files": ["hex-nexus/src/orchestration/workplan_executor.rs"],
          "done_condition": "cargo check --package hex-nexus",
          "done_command": "cargo check --package hex-nexus 2>&1 | grep -E '(error|warning)' | head -5"
        },
        {
          "id": "T1.2",
          "name": "Handle instruction types (pause/resume/stop/interrupt)",
          "layer": "adapters/secondary",
          "description": "Implement logic to react to each instruction type: pause stops execution, resume continues, interrupt injects new instructions, stop terminates",
          "deps": ["T1.1"],
          "files": ["hex-nexus/src/orchestration/workplan_executor.rs"],
          "done_condition": "cargo check --package hex-nexus",
          "done_command": "cargo build -p hex-nexus --release 2>&1 | tail -3"
        }
      ],
      "done_condition": "cargo build -p hex-nexus --release",
      "done_command": "hex-nexus compiles without errors"
    },
    {
      "id": "P2",
      "name": "Agent Execution State",
      "tier": 2,
      "tasks": [
        {
          "id": "T2.1",
          "name": "Create AgentExecutionState enum",
          "layer": "domain",
          "description": "Add AgentExecutionState enum: Running, Paused, Completed, Failed with agent_id and preserved_state fields",
          "deps": [],
          "files": ["hex-nexus/src/state.rs"],
          "done_condition": "cargo check --package hex-nexus",
          "done_command": "cargo check --package hex-nexus 2>&1 | grep -E 'error' | head -3"
        },
        {
          "id": "T2.2",
          "name": "Add state persistence for pause/resume",
          "layer": "adapters/secondary",
          "description": "Store AgentExecutionState in state so paused agents can resume later",
          "deps": ["T2.1"],
          "files": ["hex-nexus/src/state.rs"],
          "done_condition": "cargo check --package hex-nexus",
          "done_command": "cargo check --package hex-nexus 2>&1 | grep -E 'error' | head -3"
        }
      ],
      "done_condition": "cargo build -p hex-nexus --release",
      "done_command": "hex-nexus builds"
    },
    {
      "id": "P3",
      "name": "Continuous Agent Loop in hex-cli",
      "tier": 3,
      "tasks": [
        {
          "id": "T3.1",
          "name": "Create agent run loop in hex-cli",
          "layer": "adapters/primary",
          "description": "New hex agent run command that polls both HexFlo tasks and steering instructions in a loop until output",
          "deps": ["T2.1"],
          "files": ["hex-cli/src/commands/agent.rs"],
          "done_condition": "cargo check --package hex-cli",
          "done_command": "cargo check --package hex-cli 2>&1 | grep -E 'error' | head -3"
        },
        {
          "id": "T3.2",
          "name": "Integrate task polling from HexFlo",
          "layer": "adapters/primary",
          "description": "In the loop, poll /api/hexflo/tasks/claim for work, execute tasks",
          "deps": ["T3.1"],
          "files": ["hex-cli/src/commands/agent.rs"],
          "done_condition": "cargo build -p hex-cli --release",
          "done_command": "cargo build -p hex-cli --release 2>&1 | tail -3"
        },
        {
          "id": "T3.3",
          "name": "Integrate steering polling",
          "layer": "adapters/primary",
          "description": "In the loop, poll /api/steering/{agent_id}/instructions and act on pause/resume/stop/interrupt",
          "deps": ["T3.2"],
          "files": ["hex-cli/src/commands/agent.rs"],
          "done_condition": "cargo build -p hex-cli --release",
          "done_command": "cargo build -p hex-cli --release 2>&1 | tail -3"
        }
      ],
      "done_condition": "cargo build -p hex-cli --release && cargo build -p hex-nexus --release",
      "done_command": "Both hex-cli and hex-nexus build"
    },
    {
      "id": "P4",
      "name": "CLI Commands for Steering",
      "tier": 4,
      "tasks": [
        {
          "id": "T4.1",
          "name": "Add hex agent pause command",
          "layer": "adapters/primary",
          "description": "hex agent pause <session_id> to pause a running agent",
          "deps": ["T1.2"],
          "files": ["hex-cli/src/commands/agent.rs"],
          "done_condition": "hex agent pause --help works",
          "done_command": "./target/release/hex agent pause --help 2>&1 | head -5"
        },
        {
          "id": "T4.2",
          "name": "Add hex agent resume command",
          "layer": "adapters/primary",
          "description": "hex agent resume <session_id> to resume a paused agent",
          "deps": ["T4.1"],
          "files": ["hex-cli/src/commands/agent.rs"],
          "done_condition": "hex agent resume --help works",
          "done_command": "./target/release/hex agent resume --help 2>&1 | head -5"
        },
        {
          "id": "T4.3",
          "name": "Add hex agent stop command",
          "layer": "adapters/primary",
          "description": "hex agent stop <session_id> to terminate a running agent",
          "deps": ["T4.2"],
          "files": ["hex-cli/src/commands/agent.rs"],
          "done_condition": "hex agent stop --help works",
          "done_command": "./target/release/hex agent stop --help 2>&1 | head -5"
        }
      ],
      "done_condition": "./target/release/hex agent --help shows pause/resume/stop",
      "done_command": "CLI shows new commands"
    },
    {
      "id": "P5",
      "name": "End-to-End Test",
      "tier": 5,
      "tasks": [
        {
          "id": "T5.1",
          "name": "Start a long-running task",
          "layer": "integration",
          "description": "Start agent run loop with a task that takes multiple turns",
          "deps": ["T3.3"],
          "files": [],
          "done_condition": "Task runs",
          "done_command": "Manual test"
        },
        {
          "id": "T5.2",
          "name": "Pause mid-flight",
          "layer": "integration",
          "description": "Send pause instruction while task is running",
          "deps": ["T5.1", "T4.1"],
          "files": [],
          "done_condition": "Paused",
          "done_command": "curl -X POST http://localhost:5555/api/steering/{id}/event -d '{\"event\":\"pause\"}'"
        },
        {
          "id": "T5.3",
          "name": "Resume after pause",
          "layer": "integration",
          "description": "Resume the paused agent and verify it continues",
          "deps": ["T5.2", "T4.2"],
          "files": [],
          "done_condition": "Resumed",
          "done_command": "curl -X POST http://localhost:5555/api/steering/{id}/event -d '{\"event\":\"resume\"}'"
        },
        {
          "id": "T5.4",
          "name": "Verify final output",
          "layer": "integration",
          "description": "Agent completes task and produces output",
          "deps": ["T5.3"],
          "files": [],
          "done_condition": "Output produced",
          "done_command": "Task completes with output"
        }
      ],
      "done_condition": "Full pipeline works: start -> pause -> resume -> output",
      "done_command": "Manual verification"
    }
  ],
  "gates": [
    {
      "id": "G1",
      "description": "Workspace compiles after each tier",
      "command": "cargo check --workspace",
      "scope": "all-crates"
    },
    {
      "id": "G2",
      "description": "hex-cli build",
      "command": "cargo build -p hex-cli --release",
      "scope": "hex-cli"
    },
    {
      "id": "G3",
      "description": "hex-nexus build",
      "command": "cargo build -p hex-nexus --release",
      "scope": "hex-nexus"
    }
  ],
  "dependencies": [
    "ADR-2604101900",
    "ADR-2604102100"
  ]
}
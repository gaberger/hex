{
  "version": "1.0.0",
  "defaults": {
    "tokenBudgets": {
      "L0": 10,
      "L1": 60,
      "L2": 300,
      "L3": 5000
    },
    "maxFileLines": 1000,
    "encoding": "utf-8",
    "indentation": "  "
  },
  "languages": {
    "typescript": {
      "grammar": "tree-sitter-typescript",
      "grammarPath": "typescript/src",
      "fileExtensions": [".ts", ".tsx"],
      "queries": {
        "L1": {
          "exports": "(export_statement) @export",
          "imports": "(import_statement) @import",
          "functions": "(function_declaration name: (identifier) @name) @func",
          "classes": "(class_declaration name: (type_identifier) @name) @class",
          "interfaces": "(interface_declaration name: (type_identifier) @name) @iface",
          "types": "(type_alias_declaration name: (type_identifier) @name) @type",
          "enums": "(enum_declaration name: (identifier) @name) @enum",
          "constants": "(lexical_declaration (variable_declarator name: (identifier) @name)) @const"
        },
        "L2": {
          "methodSignatures": "(method_signature name: (property_identifier) @name parameters: (formal_parameters) @params return_type: (type_annotation)? @ret) @method",
          "methodDefinitions": "(method_definition name: (property_identifier) @name parameters: (formal_parameters) @params return_type: (type_annotation)? @ret) @method",
          "propertySignatures": "(property_signature name: (property_identifier) @name type: (type_annotation) @type) @prop",
          "parameters": "(required_parameter pattern: (identifier) @name type: (type_annotation) @type) @param",
          "optionalParameters": "(optional_parameter pattern: (identifier) @name type: (type_annotation) @type) @param",
          "returnTypes": "(type_annotation) @ret",
          "typeParameters": "(type_parameters) @tparams"
        }
      },
      "exportDetection": "export_statement",
      "visibilityRules": {
        "public": "has export keyword",
        "private": "no export keyword or has private modifier",
        "protected": "has protected modifier"
      }
    },
    "go": {
      "grammar": "tree-sitter-go",
      "grammarPath": "src",
      "fileExtensions": [".go"],
      "queries": {
        "L1": {
          "imports": "(import_declaration) @import",
          "functions": "(function_declaration name: (identifier) @name) @func",
          "methods": "(method_declaration name: (field_identifier) @name) @method",
          "structs": "(type_declaration (type_spec name: (type_identifier) @name type: (struct_type))) @struct",
          "interfaces": "(type_declaration (type_spec name: (type_identifier) @name type: (interface_type))) @iface",
          "types": "(type_declaration (type_spec name: (type_identifier) @name)) @type",
          "constants": "(const_declaration) @const"
        },
        "L2": {
          "structFields": "(field_declaration name: (field_identifier) @name type: (_) @type) @field",
          "methodReceiver": "(method_declaration receiver: (parameter_list (parameter_declaration type: (_) @recv)) name: (field_identifier) @name) @method",
          "functionParams": "(parameter_list (parameter_declaration name: (identifier) @name type: (_) @type)) @params",
          "returnType": "(function_declaration result: (_) @ret) @func",
          "interfaceMethods": "(method_spec name: (field_identifier) @name parameters: (parameter_list) @params result: (_)? @ret) @method"
        }
      },
      "exportDetection": "capitalized_identifier",
      "visibilityRules": {
        "public": "name starts with uppercase letter",
        "private": "name starts with lowercase letter"
      }
    },
    "rust": {
      "grammar": "tree-sitter-rust",
      "grammarPath": "src",
      "fileExtensions": [".rs"],
      "queries": {
        "L1": {
          "imports": "(use_declaration) @import",
          "functions": "(function_item name: (identifier) @name) @func",
          "structs": "(struct_item name: (type_identifier) @name) @struct",
          "traits": "(trait_item name: (type_identifier) @name) @trait",
          "enums": "(enum_item name: (type_identifier) @name) @enum",
          "types": "(type_item name: (type_identifier) @name) @type",
          "constants": "(const_item name: (identifier) @name) @const",
          "impls": "(impl_item type: (type_identifier) @name) @impl"
        },
        "L2": {
          "structFields": "(field_declaration name: (field_identifier) @name type: (_) @type) @field",
          "traitMethods": "(trait_item body: (declaration_list (function_signature_item name: (identifier) @name parameters: (parameters) @params return_type: (_)? @ret))) @method",
          "implMethods": "(impl_item body: (declaration_list (function_item name: (identifier) @name parameters: (parameters) @params return_type: (_)? @ret))) @method",
          "enumVariants": "(enum_variant name: (identifier) @name body: (_)? @body) @variant",
          "lifetimes": "(lifetime) @lifetime",
          "typeParameters": "(type_parameters) @tparams",
          "whereClause": "(where_clause) @where"
        }
      },
      "exportDetection": "pub_visibility_modifier",
      "visibilityRules": {
        "public": "has pub modifier",
        "private": "no pub modifier",
        "crate": "has pub(crate) modifier"
      }
    }
  },
  "diffOptions": {
    "ignoreComments": true,
    "ignoreWhitespace": true,
    "trackRenames": false,
    "onlyExported": true
  },
  "outputFormat": {
    "sectionSeparator": "\n",
    "memberIndent": "    ",
    "visibilityMarkers": {
      "public": "+",
      "private": "-",
      "protected": "#",
      "crate": "~"
    }
  }
}

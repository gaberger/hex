{
  "permissions": {
    "allow": [
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(cd:*)",
      "mcp__plugin_context-mode_context-mode__ctx_execute_file",
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "mcp__plugin_context-mode_context-mode__ctx_execute",
      "mcp__hex__hex_orchestrate",
      "mcp__ruflo__task_create",
      "mcp__ruflo__task_update",
      "mcp__ruflo__task_complete",
      "mcp__ruflo__task_list",
      "mcp__ruflo__task_status",
      "mcp__ruflo__agent_spawn",
      "mcp__ruflo__agent_list",
      "mcp__ruflo__swarm_init",
      "mcp__ruflo__swarm_status",
      "mcp__ruflo__swarm_health",
      "mcp__ruflo__memory_store",
      "mcp__ruflo__memory_retrieve",
      "mcp__ruflo__memory_search",
      "mcp__ruflo__memory_list",
      "mcp__ruflo__agentdb_pattern-store",
      "mcp__ruflo__agentdb_pattern-search",
      "mcp__ruflo__agentdb_feedback",
      "mcp__hex__hex_analyze"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[swarm] File edit tracked'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ../../scripts/hex-statusline.cjs"
  },
  "mcpServers": {
    "ruflo": {
      "command": "/Users/gary/.nvm/versions/node/v22.18.0/bin/ruflo",
      "args": [
        "mcp",
        "start"
      ],
      "type": "stdio"
    }
  }
}

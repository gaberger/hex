{
  "companyAnnouncements": [
    "hex — Hexagonal Architecture Framework\nRun `hex analyze .` for architecture health | `hex status` for overview | `hex swarm status` for active swarms"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "hex hook post-edit",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "hex hook pre-edit",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "command": "hex hook pre-bash",
            "timeout": 3000,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "hex hook pre-agent",
            "timeout": 3000,
            "type": "command"
          }
        ],
        "matcher": "Agent"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "hex hook session-end",
            "timeout": 5000,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "hex hook session-start",
            "timeout": 10000,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "hex hook subagent-start",
            "timeout": 3000,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "hex hook subagent-stop",
            "timeout": 3000,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "hex hook route",
            "timeout": 8000,
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__hex__hex_*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "statusLine": {
    "command": "node scripts/hex-statusline.cjs",
    "type": "command"
  }
}
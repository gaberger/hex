# Template for .cargo/config.toml. Copy or merge into your local
# .cargo/config.toml (gitignored per ADR-064 — machine-specific).
#
# These aliases implement the hexagonal architecture lint gate
# (workplan: wp-hexagonal-architecture-foundation):
#   cargo hex-lint       — P1.1: clippy posture defined in clippy.toml
#   cargo adapter-check  — P1.2: adapter -> ports-only boundary scan
#                          (rule 4 is the most regression-prone). Uses
#                          --violations-only --exit-code so it is a
#                          drop-in CI primitive.
#   cargo arch-check     — P1.3: full boundary analyzer (all 7 rules);
#                          same gate used by CI.

[alias]
hex-lint = "clippy --workspace --all-targets -- -D warnings"
adapter-check = "run --quiet --package hex-cli -- analyze . --violations-only --exit-code"
arch-check = "run --quiet --package hex-cli -- analyze ."

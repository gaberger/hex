{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "description": "hex MCP tool definitions — single source of truth for CLI, MCP server, and SpacetimeDB sync",
  "tools": [
    {
      "name": "hex_analyze",
      "category": "analysis",
      "description": "Architecture health check: boundary violations, dead exports, circular deps",
      "route": { "method": "POST", "path": "/api/analyze" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "Project root path to analyze" }
        },
        "required": ["path"]
      }
    },
    {
      "name": "hex_analyze_json",
      "category": "analysis",
      "description": "Architecture health check returning raw JSON (for programmatic use)",
      "route": { "method": "POST", "path": "/api/analyze" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "Project root path to analyze" }
        },
        "required": ["path"]
      }
    },
    {
      "name": "hex_status",
      "category": "analysis",
      "description": "Show project status and service health",
      "route": { "method": "GET", "path": "/api/version" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_hexflo_swarm_init",
      "category": "swarm",
      "description": "Initialize a new swarm for coordinated multi-agent work",
      "route": { "method": "POST", "path": "/api/swarms" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Swarm name" },
          "project_id": { "type": "string", "description": "Project identifier" },
          "topology": { "type": "string", "description": "Topology: hierarchical, mesh, star" }
        },
        "required": ["name", "project_id"]
      }
    },
    {
      "name": "hex_hexflo_swarm_status",
      "category": "swarm",
      "description": "Get status of all active swarms with tasks and agents",
      "route": { "method": "GET", "path": "/api/swarms/active" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_hexflo_swarm_complete",
      "category": "swarm",
      "description": "Mark a swarm as completed (archives it while preserving data for reporting)",
      "route": { "method": "PATCH", "path": "/api/swarms/{id}" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Swarm ID to mark as completed" }
        },
        "required": ["id"]
      }
    },
    {
      "name": "hex_hexflo_swarm_fail",
      "category": "swarm",
      "description": "Mark a swarm as failed with a reason (archives it while preserving data for reporting)",
      "route": { "method": "POST", "path": "/api/swarms/{id}/fail" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Swarm ID to mark as failed" },
          "reason": { "type": "string", "description": "Reason for failure (default: 'manually failed')" }
        },
        "required": ["id"]
      }
    },
    {
      "name": "hex_hexflo_task_create",
      "category": "task",
      "description": "Create a task in a swarm",
      "route": { "method": "POST", "path": "/api/swarms/{swarm_id}/tasks" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "swarm_id": { "type": "string", "description": "Swarm ID to add task to" },
          "title": { "type": "string", "description": "Task title/description" }
        },
        "required": ["swarm_id", "title"]
      }
    },
    {
      "name": "hex_hexflo_task_list",
      "category": "task",
      "description": "List tasks in a swarm",
      "route": { "method": "GET", "path": "/api/swarms/{swarm_id}" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "swarm_id": { "type": "string", "description": "Swarm ID (omit for all)" }
        },
        "required": []
      }
    },
    {
      "name": "hex_hexflo_task_assign",
      "category": "task",
      "description": "Assign a task to an agent. Sets status to 'in_progress' and records the agent_id. Only works on tasks with 'pending' status. Pass 'version' for optimistic locking (CAS) — returns 409 on conflict. Omit version to skip check (legacy).",
      "route": { "method": "PATCH", "path": "/api/hexflo/tasks/{task_id}" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "task_id": { "type": "string", "description": "Task ID to assign" },
          "agent_id": { "type": "string", "description": "Agent ID claiming this task (from hex_agent_connect registration)" },
          "version": { "type": "integer", "description": "Expected task version for CAS (omit to skip version check)" }
        },
        "required": ["task_id", "agent_id"]
      }
    },
    {
      "name": "hex_hexflo_swarm_transfer",
      "category": "swarm",
      "description": "Transfer swarm ownership to a new agent. The current owner loses the swarm; the new owner gains it. New owner must not already own an active swarm.",
      "route": { "method": "POST", "path": "/api/swarms/{id}/transfer" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Swarm ID to transfer" },
          "new_owner_agent_id": { "type": "string", "description": "Agent ID of the new owner" }
        },
        "required": ["id", "new_owner_agent_id"]
      }
    },
    {
      "name": "hex_hexflo_agent_swarm",
      "category": "swarm",
      "description": "Get the active swarm owned by a specific agent (if any). Returns 404 if agent has no active swarm.",
      "route": { "method": "GET", "path": "/api/hex-agents/{id}/swarm" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Agent ID to look up owned swarm for" }
        },
        "required": ["id"]
      }
    },
    {
      "name": "hex_hexflo_task_complete",
      "category": "task",
      "description": "Mark a task as completed",
      "route": { "method": "PATCH", "path": "/api/hexflo/tasks/{task_id}" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "task_id": { "type": "string", "description": "Task ID to complete" },
          "result": { "type": "string", "description": "Completion result/summary" }
        },
        "required": ["task_id"]
      }
    },
    {
      "name": "hex_hexflo_memory_store",
      "category": "memory",
      "description": "Store a key-value pair in persistent memory",
      "route": { "method": "POST", "path": "/api/hexflo/memory" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "key": { "type": "string", "description": "Memory key" },
          "value": { "type": "string", "description": "Value to store" },
          "scope": { "type": "string", "description": "Scope: global, swarm, agent" }
        },
        "required": ["key", "value"]
      }
    },
    {
      "name": "hex_hexflo_memory_retrieve",
      "category": "memory",
      "description": "Retrieve a value by key from persistent memory",
      "route": { "method": "GET", "path": "/api/hexflo/memory/{key}" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "key": { "type": "string", "description": "Memory key to retrieve" }
        },
        "required": ["key"]
      }
    },
    {
      "name": "hex_hexflo_memory_search",
      "category": "memory",
      "description": "Search persistent memory by query",
      "route": { "method": "GET", "path": "/api/hexflo/memory/search" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Search query" }
        },
        "required": ["query"]
      }
    },
    {
      "name": "hex_adr_list",
      "category": "adr",
      "description": "List Architecture Decision Records",
      "route": { "method": "GET", "path": "/api/adrs" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "description": "Filter by status: proposed, accepted, deprecated, superseded" }
        },
        "required": []
      }
    },
    {
      "name": "hex_adr_search",
      "category": "adr",
      "description": "Search ADRs by keyword",
      "route": { "method": "GET", "path": "/api/adrs/search" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Search query" },
          "limit": { "type": "integer", "description": "Max results (default 10)" }
        },
        "required": ["query"]
      }
    },
    {
      "name": "hex_adr_status",
      "category": "adr",
      "description": "Show detailed status of a specific ADR",
      "route": { "method": "GET", "path": "/api/adrs/{id}" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "ADR ID (e.g. ADR-027)" }
        },
        "required": ["id"]
      }
    },
    {
      "name": "hex_adr_abandoned",
      "category": "adr",
      "description": "Find stale/abandoned proposed ADRs",
      "route": { "method": "GET", "path": "/api/adrs/abandoned" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "days": { "type": "integer", "description": "Days without update to consider abandoned (default 14)" }
        },
        "required": []
      }
    },
    {
      "name": "hex_plan_list",
      "category": "workplan",
      "description": "List existing workplans from docs/workplans/",
      "route": { "method": "LOCAL", "path": "docs/workplans/" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_plan_status",
      "category": "workplan",
      "description": "Show detailed status of a specific workplan",
      "route": { "method": "LOCAL", "path": "docs/workplans/{file}" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "file": { "type": "string", "description": "Workplan filename (e.g. feat-secrets-plan-b.json)" }
        },
        "required": ["file"]
      }
    },
    {
      "name": "hex_plan_execute",
      "category": "workplan",
      "description": "Start executing a workplan from a JSON file path. Spawns agents per task, tracks progress in SpacetimeDB.",
      "route": { "method": "POST", "path": "/api/workplan/execute" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "file": { "type": "string", "description": "Path to workplan JSON file (e.g. docs/workplans/feat-auth.json)" }
        },
        "required": ["file"]
      }
    },
    {
      "name": "hex_plan_pause",
      "category": "workplan",
      "description": "Pause the currently running workplan execution",
      "route": { "method": "POST", "path": "/api/workplan/pause" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_plan_resume",
      "category": "workplan",
      "description": "Resume a paused workplan execution",
      "route": { "method": "POST", "path": "/api/workplan/resume" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_plan_report",
      "category": "workplan",
      "description": "Get aggregate report for a workplan execution — phases, tasks, agents, gates, duration",
      "route": { "method": "GET", "path": "/api/workplan/{id}/report" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Workplan execution ID (UUID)" }
        },
        "required": ["id"]
      }
    },
    {
      "name": "hex_plan_history",
      "category": "workplan",
      "description": "List all workplan executions (active + completed + failed) from SpacetimeDB",
      "route": { "method": "GET", "path": "/api/workplan/list" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_agent_connect",
      "category": "agent",
      "description": "Register this Claude Code session (or any agent) with hex-nexus. Returns an agentId for heartbeats and task assignment.",
      "route": { "method": "POST", "path": "/api/agents/connect" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "name":        { "type": "string", "description": "Agent display name (default: auto-generated from host)" },
          "host":        { "type": "string", "description": "Hostname (default: current machine)" },
          "project_dir": { "type": "string", "description": "Project root path (default: cwd)" },
          "model":       { "type": "string", "description": "LLM model identifier (e.g. claude-opus-4-6)" },
          "session_id":  { "type": "string", "description": "Claude Code session ID (stored in metadata)" }
        },
        "required": []
      }
    },
    {
      "name": "hex_agent_disconnect",
      "category": "agent",
      "description": "Deregister an agent from hex-nexus by its agentId",
      "route": { "method": "POST", "path": "/api/agents/disconnect" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "agent_id": { "type": "string", "description": "Agent ID returned from hex_agent_connect" }
        },
        "required": ["agent_id"]
      }
    },
    {
      "name": "hex_agent_list",
      "category": "agent",
      "description": "List all agents currently registered with hex-nexus (local + remote)",
      "route": { "method": "GET", "path": "/api/agents" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_nexus_status",
      "category": "nexus",
      "description": "Check hex-nexus daemon status",
      "route": { "method": "GET", "path": "/api/version" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_nexus_start",
      "category": "nexus",
      "description": "Start the hex-nexus daemon",
      "route": null,
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_secrets_status",
      "category": "secrets",
      "description": "Show secrets backend status",
      "route": { "method": "GET", "path": "/api/secrets/status" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_secrets_has",
      "category": "secrets",
      "description": "Check if a secret key exists",
      "route": null,
      "inputSchema": {
        "type": "object",
        "properties": {
          "key": { "type": "string", "description": "Secret key to check" }
        },
        "required": ["key"]
      }
    },
    {
      "name": "hex_inference_add",
      "category": "inference",
      "description": "Register an inference endpoint (Ollama, OpenAI, Anthropic, etc.) with hex-nexus",
      "route": { "method": "POST", "path": "/api/inference/register" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique identifier for this endpoint" },
          "provider_type": { "type": "string", "description": "Provider type: ollama, openai, anthropic, etc.", "default": "ollama" },
          "url": { "type": "string", "description": "Endpoint URL (e.g. http://localhost:11434)" },
          "model": { "type": "string", "description": "Model name (e.g. llama3, gpt-4o)" },
          "key": { "type": "string", "description": "API key secret name (omit for keyless providers like local Ollama)" }
        },
        "required": ["id", "url", "model"]
      }
    },
    {
      "name": "hex_inference_list",
      "category": "inference",
      "description": "List all registered inference endpoints and their status",
      "route": { "method": "GET", "path": "/api/inference/endpoints" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_inference_test",
      "category": "inference",
      "description": "Test connectivity to a registered inference endpoint",
      "route": null,
      "inputSchema": {
        "type": "object",
        "properties": {
          "target": { "type": "string", "description": "Endpoint ID or URL to test" }
        },
        "required": ["target"]
      }
    },
    {
      "name": "hex_inference_discover",
      "category": "inference",
      "description": "Discover inference endpoints on the local network (LAN scan)",
      "route": null,
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_inference_remove",
      "category": "inference",
      "description": "Remove a registered inference endpoint",
      "route": { "method": "POST", "path": "/api/inference/providers/{provider_id}/remove" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "provider_id": { "type": "string", "description": "Provider ID to remove" }
        },
        "required": ["provider_id"]
      }
    },
    {
      "name": "hex_inbox_notify",
      "category": "inbox",
      "description": "Send a notification to an agent or broadcast to all agents in a project (ADR-060)",
      "route": { "method": "POST", "path": "/api/hexflo/inbox/notify" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "agent_id": { "type": "string", "description": "Target agent ID (mutually exclusive with project_id)" },
          "project_id": { "type": "string", "description": "Target project ID for broadcast (mutually exclusive with agent_id)" },
          "priority": { "type": "integer", "description": "0=info, 1=warning, 2=critical", "default": 1 },
          "kind": { "type": "string", "description": "Notification kind: restart, update, shutdown, config_change, info" },
          "payload": { "type": "string", "description": "JSON payload with event-specific data", "default": "{}" }
        },
        "required": ["kind"]
      }
    },
    {
      "name": "hex_inbox_query",
      "category": "inbox",
      "description": "Query an agent's notification inbox (ADR-060)",
      "route": { "method": "GET", "path": "/api/hexflo/inbox/{agent_id}" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "agent_id": { "type": "string", "description": "Agent ID to query inbox for" },
          "min_priority": { "type": "integer", "description": "Minimum priority filter (0-2)", "default": 0 },
          "unacked_only": { "type": "boolean", "description": "Only show unacknowledged notifications", "default": true }
        },
        "required": ["agent_id"]
      }
    },
    {
      "name": "hex_inbox_ack",
      "category": "inbox",
      "description": "Acknowledge a notification (only the target agent can ack) (ADR-060)",
      "route": { "method": "PATCH", "path": "/api/hexflo/inbox/{id}/ack" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "notification_id": { "type": "integer", "description": "Notification ID to acknowledge" },
          "agent_id": { "type": "string", "description": "Agent ID acknowledging the notification" }
        },
        "required": ["notification_id", "agent_id"]
      }
    },
    {
      "name": "hex_enforce_list",
      "category": "enforcement",
      "description": "List all enforcement rules (local .hex/adr-rules.toml + SpacetimeDB)",
      "route": { "method": "GET", "path": "/api/hexflo/enforcement-rules" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_enforce_mode",
      "category": "enforcement",
      "description": "Show current enforcement mode (mandatory/advisory/disabled) from .hex/project.json",
      "route": { "method": "LOCAL", "path": ".hex/project.json" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_enforce_sync",
      "category": "enforcement",
      "description": "Sync enforcement rules from .hex/adr-rules.toml to SpacetimeDB",
      "route": { "method": "POST", "path": "/api/hexflo/enforcement-rules" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_enforce_prompt",
      "category": "enforcement",
      "description": "Generate the enforcement system prompt for non-MCP models (ADR-2603221959 P6)",
      "route": { "method": "LOCAL", "path": "embedded:templates/enforcement-system-prompt.md" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_test_history",
      "category": "test",
      "description": "Show recent test run history with pass/fail counts and durations",
      "route": { "method": "GET", "path": "/api/test-sessions" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "description": "Max results to return (default 10)" }
        },
        "required": []
      }
    },
    {
      "name": "hex_test_trends",
      "category": "test",
      "description": "Show test pass rate trends across recent runs",
      "route": { "method": "GET", "path": "/api/test-sessions/trends" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "runs": { "type": "integer", "description": "Number of recent runs to include (default 10)" }
        },
        "required": []
      }
    },
    {
      "name": "hex_project_list",
      "category": "project",
      "description": "List all projects registered with hex-nexus",
      "route": { "method": "GET", "path": "/api/projects" },
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "hex_project_register",
      "category": "project",
      "description": "Register a project with hex-nexus for tracking and coordination",
      "route": { "method": "POST", "path": "/api/projects/register" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "Absolute path to the project root" },
          "name": { "type": "string", "description": "Optional project name (defaults to directory name)" }
        },
        "required": ["path"]
      }
    },
    {
      "name": "hex_session_start",
      "category": "lifecycle",
      "description": "Start a hex session — register agent, load context. Use this instead of hooks for non-Claude providers (ADR-2603221959)",
      "route": { "method": "POST", "path": "/api/hex-agents/connect" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_dir": { "type": "string", "description": "Project root directory" },
          "model": { "type": "string", "description": "LLM model name (e.g. llama3, qwen2, claude-sonnet)" }
        }
      }
    },
    {
      "name": "hex_session_heartbeat",
      "category": "lifecycle",
      "description": "Send heartbeat and check inbox. Call periodically to keep agent alive (ADR-2603221959)",
      "route": { "method": "POST", "path": "/api/hex-agents/heartbeat" },
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "hex_workplan_activate",
      "category": "lifecycle",
      "description": "Set the active workplan for this session. Required before mutating operations in mandatory mode (ADR-2603221959)",
      "route": { "method": "POST", "path": "/api/hexflo/memory" },
      "inputSchema": {
        "type": "object",
        "properties": {
          "workplan_id": { "type": "string", "description": "Workplan ID to activate (e.g. wp-my-feature)" }
        },
        "required": ["workplan_id"]
      }
    },
    {
      "name": "hex_git_status",
      "category": "git",
      "description": "Show git status for a project (staged, unstaged, untracked files)",

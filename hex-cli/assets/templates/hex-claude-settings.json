{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Claude Code settings template installed by `hex init`. Configures hooks, permissions, statusline, and announcements for hex-aware projects.",
  "statusLine": {
    "type": "command",
    "command": "node scripts/hex-statusline.cjs"
  },
  "hooks": {
    "SessionStart": [{
      "hooks": [{
        "type": "command",
        "command": "hex hook session-start",
        "timeout": 10000
      }]
    }],
    "SessionEnd": [{
      "hooks": [{
        "type": "command",
        "command": "hex hook session-end",
        "timeout": 5000
      }]
    }],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{
          "type": "command",
          "command": "hex hook pre-edit",
          "timeout": 5000
        }]
      },
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "hex hook pre-bash",
          "timeout": 3000
        }]
      },
      {
        "matcher": "Agent",
        "hooks": [{
          "type": "command",
          "command": "hex hook pre-agent",
          "timeout": 3000
        }]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{
          "type": "command",
          "command": "hex enforce check-file \"$TOOL_INPUT_PATH\"",
          "blocking": true,
          "timeout": 5000
        }]
      },
      {
        "hooks": [{
          "type": "command",
          "command": "hex hook observe-pre",
          "blocking": false,
          "timeout": 500
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{
          "type": "command",
          "command": "hex hook post-edit",
          "timeout": 5000
        }]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{
          "type": "command",
          "command": "hex analyze --file \"$TOOL_INPUT_PATH\" --quiet",
          "blocking": false,
          "timeout": 10000
        }]
      },
      {
        "hooks": [{
          "type": "command",
          "command": "hex hook observe-post",
          "blocking": false,
          "timeout": 500
        }]
      }
    ],
    "Stop": [
      {
        "hooks": [{
          "type": "command",
          "command": "hex hook observe-stop",
          "blocking": false,
          "timeout": 500
        }]
      },
      {
        "hooks": [{
          "type": "command",
          "command": "hex analyze --violations-only --exit-code",
          "blocking": true,
          "timeout": 30000
        }]
      }
    ],
    "SubagentStart": [{
      "hooks": [{
        "type": "command",
        "command": "hex hook subagent-start",
        "timeout": 3000
      }]
    }],
    "SubagentStop": [{
      "hooks": [{
        "type": "command",
        "command": "hex hook subagent-stop",
        "timeout": 3000
      }]
    }],
    "UserPromptSubmit": [{
      "hooks": [{
        "type": "command",
        "command": "hex hook route",
        "timeout": 8000
      }]
    }]
  },
  "permissions": {
    "allow": [
      "mcp__hex__hex_*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "companyAnnouncements": [
    "hex — Hexagonal Architecture Framework\nRun `hex analyze .` for architecture health | `hex status` for overview | `hex swarm status` for active swarms"
  ]
}

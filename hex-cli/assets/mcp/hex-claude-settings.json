{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Claude Code settings template installed by `hex init`. Configures hooks, permissions, statusline, and announcements for hex-aware projects.",
  "statusLine": {
    "type": "command",
    "command": "node hex-cli/assets/helpers/hex-statusline.cjs"
  },
  "hooks": {
    "SessionStart": [{
      "hooks": [{
        "type": "command",
        "command": "hex hook session-start",
        "timeout": 10000
      }]
    }],
    "SessionEnd": [{
      "hooks": [{
        "type": "command",
        "command": "hex hook session-end",
        "timeout": 5000
      }]
    }],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{
          "type": "command",
          "command": "hex hook pre-edit",
          "timeout": 5000
        }]
      },
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "hex hook pre-bash",
          "timeout": 3000
        }]
      },
      {
        "matcher": "Agent",
        "hooks": [{
          "type": "command",
          "command": "hex hook pre-agent",
          "timeout": 3000
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{
          "type": "command",
          "command": "hex hook post-edit",
          "timeout": 5000
        }]
      }
    ],
    "SubagentStart": [{
      "hooks": [{
        "type": "command",
        "command": "hex hook subagent-start",
        "timeout": 3000
      }]
    }],
    "SubagentStop": [{
      "hooks": [{
        "type": "command",
        "command": "hex hook subagent-stop",
        "timeout": 3000
      }]
    }],
    "UserPromptSubmit": [{
      "hooks": [{
        "type": "command",
        "command": "hex hook route",
        "timeout": 8000
      }]
    }]
  },
  "permissions": {
    "allow": [
      "mcp__hex__hex_*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "companyAnnouncements": [
    "hex — Hexagonal Architecture Framework\nRun `hex analyze .` for architecture health | `hex status` for overview | `hex swarm status` for active swarms\n\nTOOL PREFERENCE: Always prefer mcp__hex__* tools over Bash/generic equivalents. Use mcp__hex__hex_analyze instead of `hex analyze` via Bash. Use mcp__hex__hex_hexflo_* for swarm/task ops. Use mcp__hex__hex_adr_* for ADR queries. Use mcp__hex__hex_inference_* for model ops. Fall back to Bash only when no mcp__hex__ tool covers the operation."
  ]
}
